<?xml version="1.0" encoding="utf-8"?>
<CodeLite_Project Name="shatter-cpp">
  <VirtualDirectory Name="shatter-cpp">
    <VirtualDirectory Name="build">
      <File Name="../../premake4.lua"/>
    </VirtualDirectory>
    <VirtualDirectory Name="bundle">
      <File Name="../../../include/orxBundleData.inc"/>
    </VirtualDirectory>
    <VirtualDirectory Name="config">
      <File Name="../../../data/config/CreationTemplate.ini"/>
      <File Name="../../../data/config/ExtensionTemplate.ini"/>
      <File Name="../../../data/config/SettingsTemplate.ini"/>
      <File Name="../../../data/config/arena.ini"/>
      <File Name="../../../data/config/ball.ini"/>
      <File Name="../../../data/config/basic.ini"/>
      <File Name="../../../data/config/brick.ini"/>
      <File Name="../../../data/config/gameover.ini"/>
      <File Name="../../../data/config/paddle.ini"/>
      <File Name="../../../data/config/scenes.ini"/>
      <File Name="../../../data/config/score.ini"/>
      <File Name="../../../data/config/shatter-cpp.ini"/>
      <File Name="../../../data/config/shatter-cppd.ini"/>
      <File Name="../../../data/config/shatter-cppp.ini"/>
      <File Name="../../../data/config/smoke.ini"/>
      <File Name="../../../data/config/sparks.ini"/>
      <File Name="../../../data/config/title.ini"/>
      <File Name="../../../data/config/view.ini"/>
    </VirtualDirectory>
    <VirtualDirectory Name="include">
      <File Name="../../../include/Ball.h"/>
      <File Name="../../../include/Brick.h"/>
      <File Name="../../../include/GameScene.h"/>
      <File Name="../../../include/Object.h"/>
      <File Name="../../../include/Paddle.h"/>
      <File Name="../../../include/Scene.h"/>
